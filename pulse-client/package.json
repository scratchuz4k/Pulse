{
  "name": "pulse-client",
  "version": "0.1.0",
  "description": "Pulse desktop client — Electron + Vue 3 + TypeScript",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "dist": "npm run build && electron-builder --win --x64"
  },
  "build": {
    "appId": "com.pulse.client",
    "productName": "Pulse",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*"
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": true,
      "installerIcon": null,
      "uninstallerIcon": null
    }
  },
  "dependencies": {
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@electron-toolkit/utils": "^4.0.0",
    "@microsoft/signalr": "^8.0.7",
    "electron-store": "^8.2.0",
    "livekit-client": "^2.5.1",
    "node-machine-id": "^1.1.12",
    "pinia": "^2.1.7",
"vue": "^3.3.11",
    "vue-router": "^4.2.5"
  },
  "devDependencies": {
    "@types/node": "^20.10.6",
    "@vitejs/plugin-vue": "^4.5.2",
    "electron": "^28.1.0",
    "electron-builder": "^26.15.2",
    "electron-vite": "^2.0.0",
    "typescript": "^5.3.3",
    "vite": "^5.0.10",
    "vue-tsc": "^1.8.27"
  }
}
